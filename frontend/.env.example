# Copie ce fichier en ".env.local" (non suivi par Git) pour développer en local
# avec l'authentification Supabase activée.

# Supabase → Project Settings → API → Project URL
VITE_SUPABASE_URL=

# Supabase → Project Settings → API → Project API keys → anon public
VITE_SUPABASE_ANON_KEY=

# Laisser vide en local : le proxy Vite redirige déjà /api vers le backend.
# VITE_API_URL=
